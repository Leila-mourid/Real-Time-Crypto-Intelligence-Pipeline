{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlertEvent",
  "description": "Alert generated by Spark — alerts_topic",
  "type": "object",
  "required": ["alert_id", "alert_type", "severity", "symbol", "message", "triggered_at"],
  "additionalProperties": false,
  "properties": {
    "alert_id":            { "type": "string" },
    "alert_type":          { "type": "string", "enum": ["PRICE_SPIKE", "PRICE_DROP", "HIGH_VOLATILITY", "NEGATIVE_SENTIMENT", "VOLUME_SURGE"] },
    "severity":            { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "symbol":              { "type": "string" },
    "message":             { "type": "string" },
    "price_at_trigger":    { "type": ["number", "null"] },
    "price_change_pct":    { "type": ["number", "null"] },
    "volatility_score":    { "type": ["number", "null"] },
    "related_article_url": { "type": ["string", "null"] },
    "window_start":        { "type": ["string", "null"] },
    "window_end":          { "type": ["string", "null"] },
    "triggered_at":        { "type": "string", "format": "date-time" }
  }
}
