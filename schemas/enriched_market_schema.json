{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EnrichedMarketEvent",
  "description": "Spark stream-to-stream join output — enriched_market_topic",
  "type": "object",
  "required": ["symbol", "window_start", "window_end", "avg_price", "total_volume", "trade_count", "is_spike", "enriched_at"],
  "additionalProperties": false,
  "properties": {
    "symbol":                { "type": "string" },
    "window_start":          { "type": "string", "format": "date-time" },
    "window_end":            { "type": "string", "format": "date-time" },
    "open_price":            { "type": ["number", "null"], "minimum": 0 },
    "close_price":           { "type": ["number", "null"], "minimum": 0 },
    "high_price":            { "type": ["number", "null"], "minimum": 0 },
    "low_price":             { "type": ["number", "null"], "minimum": 0 },
    "avg_price":             { "type": "number", "minimum": 0 },
    "total_volume":          { "type": "number", "minimum": 0 },
    "trade_count":           { "type": "integer", "minimum": 0 },
    "price_change_pct":      { "type": ["number", "null"] },
    "volatility_score":      { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "is_spike":              { "type": "boolean" },
    "related_article_id":    { "type": ["string", "null"] },
    "related_article_title": { "type": ["string", "null"] },
    "related_article_url":   { "type": ["string", "null"] },
    "news_published_at":     { "type": ["string", "null"] },
    "fred_interest_rate":    { "type": ["number", "null"] },
    "fred_inflation_rate":   { "type": ["number", "null"] },
    "enriched_at":           { "type": "string", "format": "date-time" }
  }
}
